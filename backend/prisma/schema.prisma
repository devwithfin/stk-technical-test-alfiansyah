generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Menus {
  id          String  @id @default(uuid())
  menu_name   String
  menu_parent String?
  menu_level  Int
  menu_order  Int

  parent   Menus?  @relation("MenuToMenu", fields: [menu_parent], references: [id])
  children Menus[] @relation("MenuToMenu")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
